<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <import type="android.view.View" />

        <variable
            name="product"
            type="de.muenchen.appcenter.nimux.model.Product" />

        <variable
            name="listener"
            type="de.muenchen.appcenter.nimux.view.main.home.ProductHomeAdapter.ProductItemClickListener" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.Material3.CardView.Outlined"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginStart="12dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="8dp"
            android:onClick="@{(view)-> listener.onItemClick( product, view)}"
            android:transitionName="@{@string/pctn(product.stringSortID)}"
            app:cardCornerRadius="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="@dimen/card_border_padding">

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/home_product_item_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="@dimen/side_margin"
                    android:transitionName="@{@string/home_product_icon_transition_name(product.stringSortID)}"
                    android:visibility="@{product.productIcon == 0 ? View.GONE : View.VISIBLE}"
                    app:layout_constraintBottom_toBottomOf="@id/home_product_item_name"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@id/home_product_item_name" />

                <TextView
                    android:id="@+id/home_product_item_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:layout_goneMarginStart="0dp"
                    android:layout_marginStart="@dimen/card_border_padding"
                    android:layout_marginEnd="@dimen/card_border_padding"
                    android:text="@{product.name}"
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                    android:transitionName="@{@string/home_product_name_transition_name(product.stringSortID)}"
                    app:layout_constraintBottom_toTopOf="@id/list_manage_product_amount_layout"
                    app:layout_constraintEnd_toStartOf="@id/home_product_item_price"
                    app:layout_constraintStart_toEndOf="@id/home_product_item_icon"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/home_product_item_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/side_margin"
                    android:text="@{String.format(@string/money, product.price)}"
                    android:textAppearance="?textAppearanceBody1"
                    android:transitionName="@{@string/home_product_price_transition_name(product.stringSortID)}"
                    app:layout_constraintBaseline_toBaselineOf="@id/home_product_item_name"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/home_product_item_name" />

                <LinearLayout
                    android:id="@+id/list_manage_product_amount_layout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:visibility="@{product.refillSize == 0 ? View.GONE : View.VISIBLE}"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    android:layout_marginTop="8dp"
                    app:layout_constraintTop_toBottomOf="@id/home_product_item_name">

                    <TextView
                        android:id="@+id/list_manage_product_amount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@{Integer.toString(product.currentStock)}"
                        android:textAppearance="@style/TextAppearance.Material3.BodySmall" />

                    <TextView
                        android:id="@+id/list_manage_product_amount_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="@string/amount_left_helper"
                        android:textAppearance="@style/TextAppearance.Material3.BodySmall" />
                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="viewModel"
            type="de.muenchen.appcenter.nimux.view.manage.history.UserLogDetailViewModel" />

    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="@dimen/default_layout_padding"
        tools:context=".view.manage.history.ProductLogDetailFragment">

        <TextView
            android:id="@+id/user_log_detail_timestamp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@{viewModel.userLog.timestamp.toString()}"
            android:textAppearance="?textAppearanceOverline" />

        <TextView
            android:id="@+id/user_log_detail_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:text="@{viewModel.userLog.userID}"
            android:textAppearance="?textAppearanceHeadline5" />

        <TextView
            android:id="@+id/user_log_detail_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@{viewModel.userLog.description}"
            android:textAppearance="?textAppearanceBody1" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/user_log_detail_amount_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/amount_log_title"
                android:textAppearance="?textAppearanceBody1" />

            <TextView
                android:id="@+id/user_log_detail_amount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:text="@{Double.toString(viewModel.userLog.amount)}"
                android:textAppearance="?textAppearanceBody1" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/group_seperation_margin"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/user_log_detail_changedby_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/log_detail_changedby_title"
                android:textAppearance="?textAppearanceBody2" />

            <TextView
                android:id="@+id/user_log_detail_changedby"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="@{viewModel.userLog.changedByEmail}"
                android:textAppearance="?textAppearanceBody2" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/user_log_detail_device_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/log_detail_device_title"
                android:textAppearance="?textAppearanceBody2" />

            <TextView
                android:id="@+id/user_log_detail_device"
                android:layout_width="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_height="wrap_content"
                android:text="@{viewModel.userLog.device}"
                android:textAppearance="?textAppearanceBody2" />
        </LinearLayout>
    </LinearLayout>
</layout>